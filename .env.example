# ── Core ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET_KEY=change_me_to_a_long_random_string

# ── Database (recommended) ───────────────────────────
# Use one DATABASE_URL line OR the individual DB_* fields below.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fastapi_gemini

# ── Database (alternative) ───────────────────────────
DB_USER=postgres
DB_PASSWORD=secret
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fastapi_gemini

# ── Optional ─────────────────────────────────────────
# Set to "production" in production environments
ENVIRONMENT=development
DEBUG=false
